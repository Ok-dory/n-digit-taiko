rules_version = '2';

// Paste this into the Firebase Console: Firestore Database > Rules.
// Anyone can read the leaderboard and submit a score. Only the one admin
// account (created manually in Authentication > Users, no public sign-up
// in the app) can delete entries, for moderating inappropriate names.
service cloud.firestore {
  match /databases/{database}/documents {
    match /ranking/{entryId} {
      allow read: if true;
      allow create: if true;
      allow update: if false;
      allow delete: if request.auth != null
        && request.auth.token.email == 'zerg9021@gmail.com';
    }
  }
}
